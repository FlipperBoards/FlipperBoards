[Unit]
Description=FlipperBoards Kiosk Display
After=network-online.target
Wants=network-online.target
Conflicts=getty@tty1.service

[Service]
User=pi
Group=pi
PAMName=login
TTYPath=/dev/tty1
StandardInput=tty
StandardOutput=journal
StandardError=journal
Environment=XDG_RUNTIME_DIR=/run/user/1000
ExecStart=/usr/bin/startx /opt/flipperboards-kiosk/kiosk.sh -- :0 vt1 -nocursor
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
