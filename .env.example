# FlipperBoards startup configuration — copy to backend/.env (or export in the
# environment / docker-compose). Everything is optional; these are the defaults.
# Runtime settings (theme, MQTT broker, rotation…) are edited in the web UI.

FB_HOST=0.0.0.0
FB_PORT=8000
FB_DB_PATH=flipperboards.db
FB_UPLOAD_DIR=uploads

# Dimensions for newly created screens (a standard Vestaboard is 6x22)
FB_DEFAULT_ROWS=6
FB_DEFAULT_COLS=22

# Optional API keys — used when the corresponding web-UI setting is empty.
# Weather falls back to keyless Open-Meteo; news falls back to RSS.
FB_WEATHER_API_KEY=
FB_NEWS_API_KEY=

# Comma-separated plugin names to load (see PLUGINS.md)
FB_PLUGINS=
